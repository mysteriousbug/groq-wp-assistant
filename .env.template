# UC-01 v2 Configuration
# Copy this to .env and fill in your values

# ── LLM ──
GROQ_API_KEY=gsk_your_key_here

# ── Database ──
# SQLite (local dev — default)
DATABASE_URL=sqlite:///uc01.db

# Azure PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@yourserver.postgres.database.azure.com:5432/uc01?sslmode=require

# Azure SQL (alternative)
# DATABASE_URL=mssql+pyodbc://user:password@yourserver.database.windows.net:1433/uc01?driver=ODBC+Driver+18+for+SQL+Server

# ── File Storage ──
# Local (default)
UPLOAD_DIR=./uploads

# Azure Blob (production)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=uc01-documents
